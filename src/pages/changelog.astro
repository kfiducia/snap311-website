---
import Layout from "../layouts/Layout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { entries, formatReleaseDate, formatBuilds } from "../data/changelog";

// Visual accent per change type.
const typeStyle: Record<string, { label: string; dot: string }> = {
  Added: { label: "text-navy", dot: "bg-navy" },
  Changed: { label: "text-brand", dot: "bg-brand" },
  Fixed: { label: "text-amber-700", dot: "bg-amber-500" },
  Removed: { label: "text-muted", dot: "bg-muted" },
  Deprecated: { label: "text-muted", dot: "bg-muted" },
  Security: { label: "text-brand", dot: "bg-brand" },
};

// Preserve a sensible order, then any other types as they appear.
const typeOrder = ["Added", "Changed", "Fixed", "Removed", "Deprecated", "Security"];
function groupByType(changes: { type?: string; text: string }[]) {
  const seen = [...new Set(changes.map((c) => c.type ?? ""))];
  const order = [
    ...typeOrder.filter((t) => seen.includes(t)), // known types, in order
    ...seen.filter((t) => t && !typeOrder.includes(t)), // any other named type
    ...(seen.includes("") ? [""] : []), // untyped (flat OTA) — render last, no heading
  ];
  return order.map((type) => ({
    type,
    items: changes.filter((c) => (c.type ?? "") === type),
  }));
}
---

<Layout
  title="Changelog — Snap311"
  description="A history of user-facing changes to Snap311, the independent DC 311 reporting app."
>
  <!-- Header band -->
  <header class="bg-cream">
    <div class="mx-auto max-w-4xl px-6 py-14 sm:py-20">
      <a
        href="/"
        class="inline-flex items-center gap-1 text-sm font-semibold text-brand underline underline-offset-2 hover:text-navy"
      >
        <span aria-hidden="true">←</span> Back to Snap311
      </a>

      <h1
        class="mt-6 text-4xl font-bold tracking-tight text-navy-deep sm:text-5xl"
      >
        Changelog
      </h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-ink/80">
        Notable user-facing changes to Snap311, newest first. New features and
        fixes reach you as App Store / Play Store <strong>builds</strong>, and
        smaller updates arrive automatically as <strong>over-the-air (OTA)</strong>
         updates — no store update needed.
      </p>
    </div>
  </header>

  <main class="bg-white">
    <div class="mx-auto max-w-4xl px-6 py-14 sm:py-20">
      <div class="space-y-16">
        {
          entries.map((entry, i) => {
            const isOta = entry.kind === "ota";
            // Untyped lines are "notes" (a thank-you, a heads-up) — but only when
            // the entry also has categorized changes. A fully-untyped OTA is just
            // a flat bullet list and stays as-is.
            const hasTyped = entry.changes.some((c) => c.type);
            const notes = hasTyped ? entry.changes.filter((c) => !c.type) : [];
            const body = hasTyped
              ? entry.changes.filter((c) => c.type)
              : entry.changes;
            return (
              <section
                aria-labelledby={`entry-${i}`}
                class="grid gap-6 lg:grid-cols-[180px_1fr] lg:gap-10"
              >
                {/* Left rail: sticks while scrolling on desktop */}
                <div class="lg:sticky lg:top-10 lg:self-start">
                  <div class="flex items-center gap-3 lg:flex-col lg:items-start lg:gap-2">
                    <h2
                      id={`entry-${i}`}
                      class="text-2xl font-bold tracking-tight text-navy-deep"
                    >
                      {isOta ? `OTA → v${entry.version}` : `v${entry.version}`}
                    </h2>
                    {i === 0 && (
                      <span class="rounded-full bg-navy px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wide text-white">
                        Latest
                      </span>
                    )}
                  </div>
                  <p class="mt-1 text-xs font-semibold uppercase tracking-wide text-muted">
                    {isOta ? "Over-the-air update" : "Store build"}
                  </p>
                  <time
                    datetime={entry.date}
                    class="mt-1 block text-sm font-medium text-muted"
                  >
                    {formatReleaseDate(entry.date)}
                  </time>
                  {isOta && entry.bundle && (
                    <p class="mt-2 text-xs leading-relaxed text-muted">
                      Bundle{" "}
                      <code class="rounded bg-black/5 px-1 py-0.5 font-mono text-ink/80">
                        {entry.bundle}
                      </code>
                    </p>
                  )}
                  {entry.builds && entry.builds.length > 0 && (
                    <p
                      class={`text-xs leading-relaxed text-muted ${isOta ? "mt-1" : "mt-2"}`}
                    >
                      {isOta ? "Runs on build " : "Build "}
                      <span class="font-medium text-ink/70">
                        {formatBuilds(entry.builds)}
                      </span>
                    </p>
                  )}
                </div>

                {/* Card — changes grouped by type; untyped groups (flat OTA
                    lists) render without a heading. */}
                <div class="rounded-2xl border border-black/10 bg-white p-6 shadow-sm sm:p-8">
                  <div class="space-y-8">
                    {notes.length > 0 && (
                      <div class="space-y-2 border-l-2 border-navy/20 pl-4">
                        {notes.map((note) => (
                          <p class="text-base leading-relaxed text-ink/80">
                            {note.text}
                          </p>
                        ))}
                      </div>
                    )}
                    {groupByType(body).map((group) => (
                      <div>
                        {group.type && (
                          <h3
                            class={`mb-3 text-xs font-bold uppercase tracking-wider ${typeStyle[group.type]?.label ?? "text-muted"}`}
                          >
                            {group.type}
                          </h3>
                        )}
                        <ul class="space-y-3">
                          {group.items.map((change) => (
                            <li class="flex items-start gap-3">
                              <span
                                class={`mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full ${typeStyle[group.type]?.dot ?? "bg-brand"}`}
                                aria-hidden="true"
                              />
                              <span class="text-base leading-relaxed text-ink">
                                {change.text}
                              </span>
                            </li>
                          ))}
                        </ul>
                      </div>
                    ))}
                  </div>
                </div>
              </section>
            );
          })
        }
      </div>
    </div>
  </main>
  <SiteFooter />
</Layout>
