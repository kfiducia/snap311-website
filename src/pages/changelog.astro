---
import Layout from "../layouts/Layout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { releases, formatReleaseDate } from "../data/changelog";

// Visual accent per change type.
const typeStyle: Record<string, { label: string; dot: string }> = {
  Added: { label: "text-navy", dot: "bg-navy" },
  Changed: { label: "text-brand", dot: "bg-brand" },
  Fixed: { label: "text-amber-700", dot: "bg-amber-500" },
  Removed: { label: "text-muted", dot: "bg-muted" },
  Deprecated: { label: "text-muted", dot: "bg-muted" },
  Security: { label: "text-brand", dot: "bg-brand" },
};

// Preserve a sensible order, then any other types as they appear.
const typeOrder = ["Added", "Changed", "Fixed", "Removed", "Deprecated", "Security"];
function groupByType(changes: { type: string; text: string }[]) {
  const seen = new Set(changes.map((c) => c.type));
  const order = [
    ...typeOrder.filter((t) => seen.has(t)),
    ...[...seen].filter((t) => !typeOrder.includes(t)),
  ];
  return order.map((type) => ({
    type,
    items: changes.filter((c) => c.type === type),
  }));
}
---

<Layout
  title="Changelog — Snap311"
  description="A history of user-facing changes to Snap311, the independent DC 311 reporting app."
>
  <!-- Header band -->
  <header class="bg-cream">
    <div class="mx-auto max-w-4xl px-6 py-14 sm:py-20">
      <a
        href="/"
        class="inline-flex items-center gap-1 text-sm font-semibold text-brand underline underline-offset-2 hover:text-navy"
      >
        <span aria-hidden="true">←</span> Back to Snap311
      </a>

      <h1
        class="mt-6 text-4xl font-bold tracking-tight text-navy-deep sm:text-5xl"
      >
        Changelog
      </h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-ink/80">
        Notable user-facing changes to Snap311, newest first. Snap311 is an
        independent, unofficial way to file DC 311 service requests.
      </p>
    </div>
  </header>

  <main class="bg-white">
    <div class="mx-auto max-w-4xl px-6 py-14 sm:py-20">
      <div class="space-y-16">
        {
          releases.map((release, i) => (
            <section
              aria-labelledby={`release-${release.version}`}
              class="grid gap-6 lg:grid-cols-[180px_1fr] lg:gap-10"
            >
              {/* Left rail: version + date (sticks while scrolling on desktop) */}
              <div class="lg:sticky lg:top-10 lg:self-start">
                <div class="flex items-center gap-3 lg:flex-col lg:items-start lg:gap-2">
                  <h2
                    id={`release-${release.version}`}
                    class="text-2xl font-bold tracking-tight text-navy-deep"
                  >
                    v{release.version}
                  </h2>
                  {i === 0 && (
                    <span class="rounded-full bg-navy px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wide text-white">
                      Latest
                    </span>
                  )}
                </div>
                <time
                  datetime={release.date}
                  class="mt-1 block text-sm font-medium text-muted"
                >
                  {formatReleaseDate(release.date)}
                </time>
              </div>

              {/* Card: changes grouped by type */}
              <div class="rounded-2xl border border-black/10 bg-white p-6 shadow-sm sm:p-8">
                <div class="space-y-8">
                  {groupByType(release.changes).map((group) => (
                    <div>
                      <h3
                        class={`text-xs font-bold uppercase tracking-wider ${typeStyle[group.type]?.label ?? "text-muted"}`}
                      >
                        {group.type}
                      </h3>
                      <ul class="mt-3 space-y-3">
                        {group.items.map((change) => (
                          <li class="flex items-start gap-3">
                            <span
                              class={`mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full ${typeStyle[change.type]?.dot ?? "bg-muted"}`}
                              aria-hidden="true"
                            />
                            <span class="text-base leading-relaxed text-ink">
                              {change.text}
                            </span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
              </div>
            </section>
          ))
        }
      </div>
    </div>
  </main>
  <SiteFooter />
</Layout>
