---
// Ordered for a natural narrative: start → file → discover → track.
const shots = [
  {
    base: "/img/screenshots/home",
    alt: "Snap311 home screen showing the snap-a-photo button and common DC 311 categories",
    caption: "Start in one tap — snap a photo or pick a category.",
  },
  {
    base: "/img/screenshots/report-form",
    alt: "Snap311 new report screen with address lookup, a map pin, and guided questions",
    caption:
      "Guided forms with address lookup, a smart map pin, and only the questions your report needs.",
  },
  {
    base: "/img/screenshots/nearby",
    alt: "Snap311 nearby reports map showing open and overdue 311 issues around you",
    caption: "See what's already reported nearby — and what's overdue — before you file.",
  },
  {
    base: "/img/screenshots/my-reports",
    alt: "Snap311 My reports screen listing submitted reports with status and expected dates",
    caption: "Track every report's status, department, and expected date.",
  },
];
---

<section class="bg-navy py-16 sm:py-20" aria-labelledby="shots-heading">
  <div class="mx-auto max-w-6xl px-6">
    <h2
      id="shots-heading"
      class="text-center text-3xl font-bold tracking-tight text-white sm:text-4xl"
    >
      See it in action
    </h2>

    <div
      class="mt-12 flex snap-x snap-mandatory gap-6 overflow-x-auto pb-4 sm:grid sm:grid-cols-2 sm:gap-8 sm:overflow-visible lg:grid-cols-4"
    >
      {
        shots.map((shot, i) => (
          <figure class="flex w-[78%] flex-shrink-0 snap-center flex-col items-center sm:w-auto">
            <div class="rounded-[2.5rem] border-[6px] border-black/80 bg-black/80 p-1 shadow-2xl">
              <picture>
                <source
                  type="image/webp"
                  srcset={`${shot.base}-440.webp 440w, ${shot.base}-660.webp 660w, ${shot.base}-880.webp 880w, ${shot.base}-1320.webp 1320w`}
                  sizes="(min-width: 1024px) 22vw, (min-width: 640px) 45vw, 78vw"
                />
                <img
                  src={`${shot.base}-660.png`}
                  alt={shot.alt}
                  width="1320"
                  height="2868"
                  loading={i === 0 ? "eager" : "lazy"}
                  decoding="async"
                  class="block w-full rounded-[2rem]"
                />
              </picture>
            </div>
            <figcaption class="mt-4 max-w-xs text-center text-sm leading-relaxed text-white/80">
              {shot.caption}
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
